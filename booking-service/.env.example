# SevaLK Auth Service - Example environment variables
# Copy this file to `.env` and fill real values. Do NOT commit real secrets.

# Database (use the ConnectionStrings section name)
DefaultConnection=Host=localhost;Port=5432;Database=sevalK_auth_db;Username=sevalK_admin;Password=your-database-password

# JWT (use the JwtSettings section name)
SecretKey=your-super-secret-jwt-key-change-this-in-production-min-32-chars
Issuer=sevalK-auth-service
Audience=sevalK-api
ExpirationMinutes=60
RefreshTokenExpirationDays=7
# Email (use the EmailSettings section name)
SmtpHost=smtp.gmail.com
SmtpPort=587
SmtpUsername=your-email@gmail.com
SmtpPassword=your-app-password
FromEmail=noreply@sevalK.com
FromName=SevaLK


