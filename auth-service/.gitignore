## Ignore Visual Studio temporary files, build results, and
## common files generated by popular .NET tooling

# Build Folders
bin/
obj/
out/
publish/
artifacts/

# Visual Studio / Visual Studio Code settings
# .vs/
# .vscode/

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Mono / Unity
*.pidb
*.unityproj
*.unitypackage

# Rider
.idea/
*.sln.iml

# NuGet
# Packages
*.nupkg
packages/
project.lock.json

# Dotnet tools and artifacts
.dotnet/
artifacts/

# Logs
*.log

# Runtime files
*.runtimeconfig.dev.json
*.runtimeconfig.json

# IDE helpers
*.ide

# Temporary files
*~
*.tmp

# Local appsettings / secrets (ignore environment-specific local files)
appsettings.Development.json
appsettings.*.local.json
secrets.json

# Environment variables
.env
.env.local
.env.*.local

# Database files
*.mdf
*.ldf
*.sqlite

# Test result files
TestResults/
*.trx

# Publish output
publish/

# Rider caches
_ReSharper*/

# OS files
Thumbs.db
.DS_Store

# Node modules if present
node_modules/
