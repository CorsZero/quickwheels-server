# Copy this file to .env and update with your actual values

# Database Configuration (Shared credentials)
DB_USER=quickwheels_admin
DB_PASSWORD=CHANGE_THIS_PASSWORD

# Database Names
AUTH_DB_NAME=quickwheels_auth_db
VEHICLE_DB_NAME=quickwheels_vehicle_db
BOOKING_DB_NAME=quickwheels_booking_db

# JWT Configuration (IMPORTANT: Change SecretKey in production!)
JWT_SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHARACTER_STRING
JWT_ISSUER=quickwheels-auth-service
JWT_AUDIENCE=quickwheels-api
JWT_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_DAYS=7

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
FROM_EMAIL=your-email@gmail.com
FROM_NAME=QuickWheels

# PgAdmin Configuration
PGADMIN_EMAIL=admin@quickwheels.com
PGADMIN_PASSWORD=CHANGE_THIS_PASSWORD
