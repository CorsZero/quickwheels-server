# Database Configuration (Shared credentials for all services)
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Database Names
AUTH_DB_NAME=quickwheels_auth_db
VEHICLE_DB_NAME=quickwheels_vehicle_db
BOOKING_DB_NAME=quickwheels_booking_db

# JWT Configuration
JWT_SECRET_KEY=your_64_character_random_secret_key_replace_this_in_production_now
JWT_ISSUER=quickwheels-auth-service
JWT_AUDIENCE=quickwheels-api
JWT_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_DAYS=14

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-specific-password
FROM_EMAIL=your-email@gmail.com
FROM_NAME=QuickWheels

# PgAdmin Configuration
PGADMIN_EMAIL=admin@quickwheels.com
PGADMIN_PASSWORD=your_pgadmin_password

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET_NAME=your-s3-bucket-name
AWS_S3_SIGNED_URL_EXPIRY_MINUTES=10

# CORS Configuration
CORS_ORIGIN=http://your-server-ip-or-domain

